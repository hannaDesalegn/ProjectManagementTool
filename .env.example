# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/haytask"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server Configuration
NODE_ENV="development"
PORT=3000
CLIENT_URL="http://localhost:3000"

# Email Configuration (Gmail Example)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-gmail-app-password"
EMAIL_FROM="HayTask <noreply@haytask.com>"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET="your-session-secret-change-this"

# Optional: Redis for Caching (if using)
# REDIS_URL="redis://localhost:6379"

# Optional: AWS S3 for File Uploads (future feature)
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_S3_BUCKET="haytask-uploads"
# AWS_REGION="us-east-1"

# Optional: Sentry for Error Tracking
# SENTRY_DSN="your-sentry-dsn"

# Optional: Analytics
# GOOGLE_ANALYTICS_ID="UA-XXXXXXXXX-X"

# Security
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Feature Flags
ENABLE_EMAIL_VERIFICATION=true
ENABLE_WEBSOCKET=true
ENABLE_FILE_UPLOADS=false
