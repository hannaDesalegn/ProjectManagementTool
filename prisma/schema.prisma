
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceType {
  PERSONAL
  TEAM
  ORGANIZATION
}

enum MembershipRole {
  Owner
  Admin
  Member
  Viewer
}

enum ProjectStatus {
  Active
  Archived
  Completed
}

enum CardStatus {
  ToDo
  InProgress
  Done
}

enum WorkspacePlan {
  FREE
  PRO
  BUSINESS
}

enum VerificationStatus {
  PENDING
  DOMAIN_VERIFIED
  APPROVED
  REJECTED
}

enum TeamRole {
  Lead
  Member
  Viewer
}

enum ProjectRole {
  ProjectAdmin
  Contributor
  Viewer
}

enum CardPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AuditTargetType {
  Workspace
  Team
  Project
  Board
  List
  Card
  Membership
  TeamMembership
  ProjectMembership
  Verification
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  email           String   @unique
  password_hash   String
  profile_pic     String?
  is_system_admin Boolean  @default(false)
  
  // Auth Fields
  isVerified           Boolean   @default(false)
  verificationToken    String?   @unique
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  
  created_at      DateTime @default(now())
  deleted_at      DateTime?

  owned_workspace    Workspace[]        @relation("WorkspaceOwner")
  memberships         Membership[]
  assigned_cards      Card[]             @relation("UserAssignedCards")
  team_memberships   TeamMembership[]
  project_memberships ProjectMembership[]
  activity_logs       ActivityLog[]
  comments            Comment[]
  reactions           Reaction[]
}

model Workspace {
  id                  String             @id @default(uuid()) @db.Uuid
  name                String
  type                WorkspaceType
  owner_id            String             @db.Uuid
  verified            Boolean            @default(false)
  plan                WorkspacePlan      @default(FREE)
  member_limit        Int                @default(15)
  current_members     Int                @default(1)
  verification_status VerificationStatus @default(PENDING)
  verified_at         DateTime?
  verification_notes  String?
  org_domain          String?
  legal_name          String?
  registration_id     String?
  website             String?
  created_at          DateTime           @default(now())
  deleted_at          DateTime?

  owner          User          @relation("WorkspaceOwner", fields: [owner_id], references: [id], onDelete: Cascade)
  memberships    Membership[]
  teams          Team[]
  projects       Project[]
  boards         Board[]
  cards          Card[]
  activity_logs  ActivityLog[]
  invitations    Invitation[]

  // Hierarchy support (Departments)
  parent_workspace_id String?    @db.Uuid
  parent              Workspace? @relation("WorkspaceHierarchy", fields: [parent_workspace_id], references: [id])
  divisions           Workspace[] @relation("WorkspaceHierarchy")

  @@index([owner_id])
  @@index([type])
  @@index([plan])
  @@index([org_domain])
}

model Membership {
  id           String         @id @default(uuid()) @db.Uuid
  user_id      String         @db.Uuid
  workspace_id String         @db.Uuid
  role         MembershipRole
  title        String?        // e.g., "Frontend Lead", "CEO"
  permissions  Json?          // Granular capability toggles
  joined_at    DateTime       @default(now())
  left_at      DateTime?

  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([user_id, workspace_id])
  @@index([workspace_id])
  @@index([user_id])
}

model Team {
  id           String            @id @default(uuid()) @db.Uuid
  workspace_id String            @db.Uuid
  name         String
  created_at   DateTime          @default(now())
  deleted_at   DateTime?

  workspace   Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  memberships TeamMembership[]
  projects    Project[]


@@index([workspace_id])
}

model TeamMembership {
  id        String   @id @default(uuid()) @db.Uuid
  team_id   String   @db.Uuid
  user_id   String   @db.Uuid
  role      TeamRole
  joined_at DateTime @default(now())
  left_at   DateTime?

  team Team @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([team_id, user_id])
  @@index([team_id])
  @@index([user_id])
}

model Project {
  id           String      @id @default(uuid()) @db.Uuid
  workspace_id String      @db.Uuid
  team_id      String?     @db.Uuid
  name         String
  description  String?      @db.Text
  status       ProjectStatus
  is_public    Boolean      @default(false)
  start_date   DateTime     @db.Date
  end_date     DateTime    @db.Date
  created_at   DateTime    @default(now())
  deleted_at   DateTime?

  workspace           Workspace         @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  team                Team?             @relation(fields: [team_id], references: [id], onDelete: SetNull)
  boards              Board[]
  project_memberships ProjectMembership[]

  @@index([workspace_id])
  @@index([team_id])
}

model ProjectMembership {
  id         String      @id @default(uuid()) @db.Uuid
  project_id String      @db.Uuid
  user_id    String      @db.Uuid
  role       ProjectRole
  joined_at  DateTime    @default(now())
  left_at    DateTime?

  project Project @relation(fields: [project_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([project_id, user_id])
  @@index([project_id])
  @@index([user_id])
}

model Board {
  id               String    @id @default(uuid()) @db.Uuid
  project_id       String    @db.Uuid
  workspace_id     String    @db.Uuid
  name             String
  background_color String?   // Board background color
  created_at       DateTime  @default(now())
  deleted_at       DateTime?

  project   Project   @relation(fields: [project_id], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  lists     List[]
  cards     Card[]
  config    Json?     // Views preferences (Kanban, List, Calendar)

  @@index([project_id])
  @@index([workspace_id])
}

model List {
  id         String   @id @default(uuid()) @db.Uuid
  board_id   String   @db.Uuid
  name       String
  position   Float
  created_at DateTime @default(now())
  deleted_at DateTime?

  board Board @relation(fields: [board_id], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([board_id])
}

model Card {
  id           String   @id @default(uuid()) @db.Uuid
  list_id      String   @db.Uuid
  board_id     String   @db.Uuid
  workspace_id String   @db.Uuid
  title        String
  description  String?  @db.Text
  status       CardStatus   @default(ToDo)
  priority     CardPriority? @default(MEDIUM)
  position     Float     @default(0) // For ultra-smooth drag-and-drop
  metadata     Json?     // Custom fields (Value, Story Points, etc.)
  labels       Json?     // List of tags/labels
  color        String?   // Card background color
  due_date     DateTime?
  assigned_to  String?  @db.Uuid
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  deleted_at   DateTime?

  // Recursive Sub-tasks
  parent_id String? @db.Uuid
  parent    Card?   @relation("CardHierarchy", fields: [parent_id], references: [id])
  subtasks  Card[]  @relation("CardHierarchy")

  list      List      @relation(fields: [list_id], references: [id], onDelete: Cascade)
  board     Board     @relation(fields: [board_id], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  assignee  User?     @relation("UserAssignedCards", fields: [assigned_to], references: [id], onDelete: SetNull)
  
  // Structured Content
  checklists  ChecklistItem[]
  comments    Comment[]
  reactions   Reaction[]

  @@index([list_id])
  @@index([board_id])
  @@index([workspace_id])
  @@index([assigned_to])
  @@index([parent_id])
}


model ChecklistItem {
  id           String   @id @default(uuid()) @db.Uuid
  card_id      String   @db.Uuid
  content      String
  is_completed Boolean  @default(false)
  position     Float    @default(0)
  created_at   DateTime @default(now())

  card Card @relation(fields: [card_id], references: [id], onDelete: Cascade)

  @@index([card_id])
}

model Comment {
  id         String   @id @default(uuid()) @db.Uuid
  card_id    String   @db.Uuid
  user_id    String   @db.Uuid
  content    String   @db.Text
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  card Card @relation(fields: [card_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([card_id])
}

model Reaction {
  id         String @id @default(uuid()) @db.Uuid
  card_id    String @db.Uuid
  user_id    String @db.Uuid
  emoji      String

  card Card @relation(fields: [card_id], references: [id], onDelete: Cascade)
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([card_id])
}

model ActivityLog {
  id          String          @id @default(uuid()) @db.Uuid
  actor_id    String          @db.Uuid
  workspace_id String         @db.Uuid
  target_type AuditTargetType
  target_id   String          @db.Uuid
  action      String
  metadata    Json?
  created_at  DateTime        @default(now())

  actor     User      @relation(fields: [actor_id], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([actor_id])
  @@index([workspace_id])
  @@index([target_type])
  @@index([target_id])
}

model Invitation {
  id           String         @id @default(uuid()) @db.Uuid
  workspace_id String         @db.Uuid
  email        String?        // Optional: Specific email or general link
  role         MembershipRole
  title        String?        // Pre-defined title for the new member
  token        String         @unique
  expires_at   DateTime
  created_at   DateTime       @default(now())

  workspace    Workspace      @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@index([workspace_id])
  @@index([token])
}